.skeleton-container {
  background-color: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.pulse {
  background: linear-gradient(90deg, #f2f2f2 25%, #e6e6e6 37%, #f2f2f2 63%);
  background-size: 400% 100%;
  animation: skeleton-loading 1.4s ease infinite;
}

@keyframes skeleton-loading {
  0% { background-position: 100% 50%; }
  100% { background-position: 0 50%; }
}

.skeleton-title {
  width: 200rpx;
  height: 40rpx;
  border-radius: 8rpx;
  margin-bottom: 30rpx;
}

.skeleton-item {
  display: flex;
  align-items: center;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.skeleton-text-group {
  flex: 1;
}

.skeleton-text {
  width: 100%;
  height: 30rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.skeleton-text.short {
  width: 60%;
}