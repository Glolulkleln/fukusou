page {
  background-color: #f7f8fa;
}

.tab-bar {
  display: flex;
  background-color: #ffffff;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  z-index: 99;
  border-bottom: 2rpx solid #f2f2f2;
}

.tab-item {
  flex: 1;
  text-align: center;
  line-height: 88rpx;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #000000;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #000000;
  border-radius: 4rpx;
}

.order-list {
  padding: 108rpx 20rpx 40rpx 20rpx;
}

.empty-state {
  text-align: center;
  padding-top: 200rpx;
  color: #999999;
  font-size: 28rpx;
}

.list-footer {
  text-align: center;
  color: #bbbbbb;
  font-size: 24rpx;
  padding: 30rpx 0;
}

.order-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  padding: 0 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  border-bottom: 2rpx solid #f9f9f9;
}

.order-no {
  font-size: 24rpx;
  color: #999999;
}

.order-status {
  font-size: 26rpx;
  font-weight: bold;
}

.order-status.processing {
  color: #ff4d4f;
}

.order-status.done {
  color: #52c41a;
}

.order-content {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f9f9f9;
}

.clothing-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  background-color: #f2f2f2;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.clothing-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
}

.clothing-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
}

.clothing-spec, .rent-dates {
  font-size: 24rpx;
  color: #999999;
}

.order-footer {
  padding: 24rpx 0;
}

.price-info {
  text-align: right;
  font-size: 26rpx;
  color: #333333;
  margin-bottom: 20rpx;
}

.total-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #000000;
}

.deposit-hint {
  font-size: 22rpx;
  color: #999999;
  margin-left: 10rpx;
}

.action-bar {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.btn {
  font-size: 26rpx;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  text-align: center;
}

.default-btn {
  color: #666666;
  border: 2rpx solid #cccccc;
  background-color: transparent;
}

.primary-btn {
  color: #ffffff;
  background-color: #000000;
  border: 2rpx solid #000000;
}

.warning-btn {
  color: #ff9900;
  border: 2rpx solid #ff9900;
  background-color: #fffaf0;
}