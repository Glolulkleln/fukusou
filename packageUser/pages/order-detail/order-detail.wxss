page {
  background-color: #f7f8fa;
  padding-bottom: 40rpx;
}

.status-banner {
  background-color: #000000;
  padding: 60rpx 40rpx;
  color: #ffffff;
}

.status-banner .status-txt {
  font-size: 38rpx;
  font-weight: bold;
}

.timeline-card {
  background: #fff;
  margin: 20rpx;
  border-radius: 12rpx;
  padding: 30rpx 30rpx 30rpx 20rpx;
}
.timeline-item {
  display: flex;
  align-items: flex-start;
  position: relative;
  padding-bottom: 30rpx;
}
.timeline-item:last-child { padding-bottom: 0; }
.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #c0c4cc;
  margin: 8rpx 24rpx 0 8rpx;
  flex-shrink: 0;
}
.timeline-item.done .timeline-dot { background: #67c23a; }
.timeline-item.cancel .timeline-dot { background: #f56c6c; }
.timeline-body { flex: 1; }
.timeline-title { font-size: 28rpx; color: #303133; }
.timeline-item:not(.done) .timeline-title { color: #c0c4cc; }
.timeline-desc { font-size: 24rpx; color: #909399; margin-top: 6rpx; }

.express-card {
  background: linear-gradient(135deg, #1a1a1a 0%, #333333 100%);
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  color: #ffffff;
}

.express-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.express-icon {
  width: 72rpx;
  height: 72rpx;
  background-color: #ffd700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.express-icon-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.express-title {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.express-company {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.express-status {
  font-size: 24rpx;
  color: #ffd700;
}

.express-no-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.express-no-label {
  font-size: 26rpx;
  color: #cccccc;
}

.express-no-content {
  display: flex;
  align-items: center;
}

.express-no {
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.copy-btn {
  font-size: 24rpx;
  color: #ffd700;
  margin-left: 16rpx;
  padding: 6rpx 16rpx;
  border: 1rpx solid #ffd700;
  border-radius: 20rpx;
}

.info-card {
  background-color: #ffffff;
  margin: 20rpx 20rpx 0 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  border-left: 6rpx solid #000000;
  padding-left: 16rpx;
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #666666;
  padding: 14rpx 0;
}

.info-item .label {
  color: #999999;
  min-width: 160rpx;
}

.info-item .value {
  color: #333333;
  text-align: right;
}

.info-item .address-text {
  text-align: left;
  line-height: 1.4;
  padding-left: 20rpx;
}

.clothing-row {
  display: flex;
  padding-top: 10rpx;
}

.clothing-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background-color: #e0e0e0;
  margin-right: 24rpx;
}

.clothing-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.clothing-meta .name {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
}

.clothing-meta .spec {
  font-size: 24rpx;
  color: #999999;
}

.clothing-meta .price {
  font-size: 26rpx;
  color: #333333;
}

.total-row {
  margin-top: 10rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f2f2f2;
}

.font-bold {
  font-weight: bold;
  color: #333333 !important;
}

.price-highlight {
  color: #ff4d4f !important;
  font-size: 32rpx;
  font-weight: bold;
}

.action-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.btn {
  font-size: 26rpx;
  padding: 14rpx 36rpx;
  border-radius: 36rpx;
  text-align: center;
}

.default-btn {
  color: #666666;
  border: 2rpx solid #cccccc;
  background-color: transparent;
}

.primary-btn {
  color: #ffffff;
  background-color: #000000;
  border: 2rpx solid #000000;
}

.warning-btn {
  color: #ff9900;
  border: 2rpx solid #ff9900;
  background-color: #fffaf0;
}

.disabled-btn {
  color: #999999;
  border: 2rpx solid #e0e0e0;
  background-color: #f5f5f5;
}

.pay-popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.pay-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  padding-bottom: env(safe-area-inset-bottom);
}

.pay-popup.show {
  transform: translateY(0);
}

.pay-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f2f2f2;
}

.pay-popup-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.pay-popup-close {
  width: 50rpx;
  height: 50rpx;
  line-height: 46rpx;
  text-align: center;
  font-size: 40rpx;
  color: #999999;
}

.pay-method-list {
  padding: 20rpx 30rpx;
}

.pay-method-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 20rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.pay-method-item:last-child {
  border-bottom: none;
}

.pay-method-item.active {
  background-color: #fafafa;
  border-radius: 12rpx;
}

.pay-method-left {
  display: flex;
  align-items: center;
}

.pay-icon {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 12rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.wechat-icon {
  background-color: #07c160;
}

.alipay-icon {
  background-color: #1677ff;
}

.mock-icon {
  background-color: #ff7a00;
}

.pay-method-info {
  display: flex;
  flex-direction: column;
}

.pay-method-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.pay-method-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 6rpx;
}

.pay-radio {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #d9d9d9;
  border-radius: 50%;
  position: relative;
}

.pay-radio.checked {
  border-color: #ff4d4f;
}

.pay-radio.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 18rpx;
  height: 18rpx;
  background-color: #ff4d4f;
  border-radius: 50%;
}

.pay-popup-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-top: 2rpx solid #f2f2f2;
}

.pay-amount {
  display: flex;
  align-items: baseline;
}

.pay-amount-label {
  font-size: 28rpx;
  color: #666666;
}

.pay-amount-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff4d4f;
  margin-left: 10rpx;
}

.pay-confirm-btn {
  width: 280rpx;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  background-color: #ff4d4f;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 42rpx;
}

.pay-confirm-btn.disabled {
  background-color: #ffb3b3;
}