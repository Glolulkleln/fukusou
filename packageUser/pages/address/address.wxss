page {
  background-color: #f7f8fa;
  padding-bottom: 120rpx;
}

.empty-state {
  text-align: center;
  padding-top: 200rpx;
  color: #999999;
  font-size: 28rpx;
}

.loading-state {
  text-align: center;
  color: #999999;
  font-size: 28rpx;
  padding: 100rpx 0;
}

.address-list {
  padding: 20rpx;
}

.address-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}

.item-main {
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f2f2f2;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-right: 20rpx;
}

.phone {
  font-size: 28rpx;
  color: #666666;
}

.default-tag {
  font-size: 20rpx;
  color: #ff4d4f;
  background-color: #fff0f0;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-left: 20rpx;
  border: 2rpx solid #ff4d4f;
}

.address-detail {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.4;
}

.item-bar {
  display: flex;
  justify-content: flex-end;
  padding-top: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #999999;
  padding: 6rpx 20rpx;
  border: 2rpx solid #cccccc;
  border-radius: 26rpx;
  margin-left: 20rpx;
}

.action-btn.primary {
  color: #ffffff;
  background-color: #ff4d4f;
  border-color: #ff4d4f;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.04);
  padding-bottom: env(safe-area-inset-bottom);
}

.add-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #000000;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 40rpx;
}