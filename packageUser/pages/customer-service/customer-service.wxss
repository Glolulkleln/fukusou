.cs-container { padding: 24rpx; background: #f5f7fa; min-height: 100vh; }
.cs-card { background: #fff; border-radius: 12rpx; padding: 12rpx 24rpx; }
.cs-row { display: flex; justify-content: space-between; align-items: center; padding: 28rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.cs-row:last-child { border-bottom: none; }
.cs-label { font-size: 28rpx; color: #303133; }
.cs-value { font-size: 26rpx; color: #606266; }
.cs-tip { font-size: 24rpx; color: #909399; text-align: center; margin: 24rpx 0; }
.cs-btn { background: #409eff; color: #fff; text-align: center; padding: 24rpx 0; border-radius: 12rpx; font-size: 28rpx; }
