.help-container { padding: 24rpx; background: #f5f7fa; min-height: 100vh; }
.help-title { font-size: 32rpx; font-weight: bold; color: #303133; margin-bottom: 20rpx; }
.faq-card { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 20rpx; }
.faq-q { font-size: 28rpx; font-weight: bold; color: #409eff; }
.faq-a { font-size: 26rpx; color: #606266; margin-top: 12rpx; line-height: 1.6; }
.tip { text-align: center; color: #909399; font-size: 24rpx; margin-top: 20rpx; }
