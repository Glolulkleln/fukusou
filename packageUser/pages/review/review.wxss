page {
  background-color: #f7f8fa;
}

.review-container {
  padding: 30rpx;
}

.score-box {
  background-color: #ffffff;
  padding: 40rpx 30rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.score-box .label {
  font-size: 30rpx;
  color: #333333;
  font-weight: bold;
  margin-right: 40rpx;
}

.stars {
  display: flex;
}

.star-item {
  font-size: 50rpx;
  color: #e0e0e0;
  margin-right: 20rpx;
}

.star-item.active {
  color: #ff9900;
}

.content-box {
  background-color: #ffffff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 40rpx;
}

.review-textarea {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.image-uploader {
  display: flex;
  flex-wrap: wrap;
  padding-top: 20rpx;
  border-top: 2rpx solid #f2f2f2;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
}

.uploaded-img {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.delete-btn {
  position: absolute;
  top: -16rpx;
  right: -16rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0,0,0,0.6);
  color: #ffffff;
  border-radius: 50%;
  text-align: center;
  line-height: 36rpx;
  font-size: 32rpx;
}

.upload-btn {
  width: 160rpx;
  height: 160rpx;
  background-color: #f7f8fa;
  border: 2rpx dashed #cccccc;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.upload-btn .plus {
  font-size: 60rpx;
  color: #cccccc;
  line-height: 1;
  margin-bottom: 8rpx;
}

.upload-btn .txt {
  font-size: 22rpx;
  color: #999999;
}

.submit-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background-color: #000000;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 44rpx;
}