page {
  background-color: #f7f8fa;
  padding-bottom: 110rpx;
}

.cart-list {
  padding: 20rpx;
}

.empty-cart {
  text-align: center;
  padding-top: 200rpx;
  color: #999999;
  font-size: 28rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}

.checkbox-box {
  padding-right: 20rpx;
  height: 100%;
  display: flex;
  align-items: center;
}

.item-content {
  flex: 1;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.clothing-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background-color: #e0e0e0;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.clothing-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 140rpx;
  overflow: hidden;
}

.clothing-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.clothing-spec {
  font-size: 24rpx;
  color: #999999;
}

.rent-days {
  font-size: 24rpx;
  color: #666666;
}

.rent-days-row {
  display: flex;
  align-items: center;
}

.rent-days-label {
  font-size: 24rpx;
  color: #666666;
  margin-right: 16rpx;
}

.days-stepper {
  display: flex;
  align-items: center;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
}

.days-btn {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333333;
  background-color: #f5f5f5;
}

.days-count {
  min-width: 80rpx;
  text-align: center;
  font-size: 26rpx;
  color: #333333;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rent-price {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.deposit-amount {
  font-size: 22rpx;
  color: #999999;
}

.delete-action {
  font-size: 24rpx;
  color: #ff4d4f;
  padding-left: 24rpx;
  height: 100%;
  display: flex;
  align-items: center;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.04);
  z-index: 90;
  padding-bottom: env(safe-area-inset-bottom);
}

.select-all {
  display: flex;
  align-items: center;
}

.all-txt {
  font-size: 26rpx;
  color: #333333;
  margin-left: 12rpx;
}

.total-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  padding-right: 24rpx;
}

.total-line {
  font-size: 28rpx;
  color: #333333;
}

.total-line .price {
  font-size: 34rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.sub-line {
  font-size: 20rpx;
  color: #999999;
  margin-top: 4rpx;
}

.checkout-btn {
  width: 200rpx;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  background-color: #000000;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 38rpx;
}