page {
  background-color: #f7f8fa;
}

.profile-container {
  width: 100%;
}

.user-info {
  background-color: #ffffff;
  padding: 60rpx 40rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background-color: #e0e0e0;
  margin-right: 30rpx;
}

.info-text {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.phone {
  font-size: 28rpx;
  color: #999999;
}

.login-btn {
  background-color: #000000;
  color: #ffffff;
  font-size: 28rpx;
  padding: 0 40rpx;
  border-radius: 40rpx;
  margin: 0;
  line-height: 60rpx;
}

.hint {
  font-size: 24rpx;
  color: #999999;
  margin-top: 10rpx;
}

.menu-list {
  background-color: #ffffff;
}

.menu-item {
  padding: 30rpx 40rpx;
  border-bottom: 2rpx solid #f2f2f2;
  font-size: 30rpx;
  color: #333333;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.menu-btn {
  width: 100% !important;
  background-color: transparent;
  padding: 30rpx 40rpx;
  margin: 0 !important;
  font-weight: normal;
  border-radius: 0;
  text-align: left;
  border-bottom: 2rpx solid #f2f2f2;
  font-size: 30rpx;
  color: #333333;
  display: flex;
  justify-content: space-between;
  align-items: center;
  line-height: inherit;
}

.menu-btn::after {
  border: none;
}

.arrow {
  color: #cccccc;
  font-family: consolas;
}