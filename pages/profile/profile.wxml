<view class="profile-container">
  <view class="user-info">
    <image class="avatar" src="{{userInfo.avatar_url || '/assets/icons/profile.png'}}" mode="aspectFill"></image>
    <view class="info-text" wx:if="{{hasLogin}}">
      <text class="nickname">{{userInfo.nickname}}</text>
      <view class="phone-row">
        <text class="phone">{{userInfo.phone || '未绑定手机号'}}</text>
        <button wx:if="{{!userInfo.phone}}" class="bind-phone-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhone">绑定手机号</button>
      </view>
    </view>
    <view class="info-text" wx:else>
      <button class="login-btn" bindtap="handleLogin">微信授权登录</button>
      <text class="hint">一键登录，体验完整功能</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goToOrder">
      <text>我的订单</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToFavorite">
      <text>我的收藏</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToDeposit">
      <text>押金钱包</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToAddress">
      <text>收货地址</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToHelp">
      <text>帮助中心</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToCustomerService">
      <text>联系客服</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToAbout">
      <text>关于我们</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>