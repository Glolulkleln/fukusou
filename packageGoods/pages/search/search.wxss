page {
  background-color: #f7f8fa;
}

.search-header {
  background-color: #ffffff;
  padding: 24rpx 30rpx;
  border-bottom: 2rpx solid #f2f2f2;
}

.search-header .tip {
  font-size: 26rpx;
  color: #666666;
}

.result-list {
  padding: 20rpx;
}

.empty-box {
  text-align: center;
  padding-top: 160rpx;
  font-size: 28rpx;
  color: #999999;
}

.loading-state {
  text-align: center;
  color: #999999;
  font-size: 28rpx;
  padding: 100rpx 0;
}

.clothing-card {
  display: flex;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}

.card-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #e0e0e0;
  margin-right: 24rpx;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.clothing-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rent-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.deposit-amount {
  font-size: 24rpx;
  color: #999999;
}